---
import type { LanguageCode } from "../i18n";
import { DEFAULT_LANG, ui, LANGUAGES } from "../i18n";
interface Props { lang?: LanguageCode }
const { lang = DEFAULT_LANG } = Astro.props;
const t = (k: keyof typeof ui.en) => (ui as any)[lang]?.[k] ?? ui.en[k];
const year = new Date().getFullYear();
const prefix = lang === "en" ? "" : `/${lang}`;
---
<footer class="mt-auto border-t border-stone-200 dark:border-stone-800 bg-stone-100 dark:bg-stone-950">
  <!-- CTA strip -->
  <div class="bg-gradient-to-r from-primary-800 to-primary-700 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <p class="text-lg font-bold">Get the GenAI Playbook PDF — free</p>
        <p class="text-sm text-primary-100 mt-1">Download all 21 chapters in your language. No email required.</p>
      </div>
      <div class="flex gap-3 flex-wrap justify-center">
        <a href="/downloads/genai-playbook-en.pdf" download class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-4 py-2.5 text-stone-900 font-semibold text-sm hover:bg-accent-400 transition">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
          GenAI Playbook PDF
        </a>
        <a href="/downloads/agentic-ai-playbook-en.pdf" download class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 px-4 py-2.5 text-white font-semibold text-sm hover:bg-white/20 transition">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>
          Agentic AI Playbook PDF
        </a>
      </div>
    </div>
  </div>

  <!-- Main footer -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-5 text-sm">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2.5 mb-3">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary-600">
            <svg class="h-5 w-5" viewBox="0 0 32 32" fill="none" aria-hidden="true">
              <g stroke="#fff" stroke-width="2.6" stroke-linecap="round" transform="translate(16 16)">
                <line x1="0" y1="-9" x2="0" y2="9"/>
                <line x1="-7.8" y1="-4.5" x2="7.8" y2="4.5"/>
                <line x1="-7.8" y1="4.5" x2="7.8" y2="-4.5"/>
              </g>
              <circle cx="16" cy="16" r="2.4" fill="#fbbf24" />
            </svg>
          </span>
          <span class="font-bold text-stone-900 dark:text-stone-50">What Generative AI</span>
        </div>
        <p class="text-stone-600 dark:text-stone-400 max-w-sm leading-relaxed">{t("tagline")}. Open-source under Apache 2.0. Available in 10 languages. Author: <a href="https://www.dipankar.co" class="text-primary-700 hover:underline">Dipankar Sarkar</a>.</p>
        <!-- Social -->
        <div class="mt-4 flex gap-3">
          <a href="https://github.com/dipankar/whatgenerativeai" aria-label="GitHub" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-stone-300 dark:border-stone-700 text-stone-600 dark:text-stone-400 hover:bg-primary-600 hover:text-white hover:border-primary-600 transition">
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/dipankarsarkar" aria-label="LinkedIn" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-stone-300 dark:border-stone-700 text-stone-600 dark:text-stone-400 hover:bg-primary-600 hover:text-white hover:border-primary-600 transition">
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://twitter.com/dipankarsarkar" aria-label="X / Twitter" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-stone-300 dark:border-stone-700 text-stone-600 dark:text-stone-400 hover:bg-primary-600 hover:text-white hover:border-primary-600 transition">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="/rss.xml" aria-label="RSS" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-stone-300 dark:border-stone-700 text-stone-600 dark:text-stone-400 hover:bg-accent-500 hover:text-stone-900 hover:border-accent-500 transition">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
          </a>
        </div>
      </div>

      <!-- Playbooks -->
      <div>
        <p class="font-semibold text-stone-800 dark:text-stone-100 mb-3">Playbooks</p>
        <ul class="space-y-2 text-stone-600 dark:text-stone-400">
          <li><a class="hover:text-primary-700" href={`${prefix}/docs/genai-playbook/`}>GenAI Playbook</a></li>
          <li><a class="hover:text-primary-700" href={`${prefix}/docs/genai-playbook/from-genai-to-agentic-ai/`}>Agentic AI Playbook</a></li>
          <li><a class="hover:text-primary-700" href="/downloads/genai-playbook-en.pdf">Download PDF (GenAI)</a></li>
          <li><a class="hover:text-primary-700" href="/downloads/agentic-ai-playbook-en.pdf">Download PDF (Agentic)</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="font-semibold text-stone-800 dark:text-stone-100 mb-3">Resources</p>
        <ul class="space-y-2 text-stone-600 dark:text-stone-400">
          <li><a class="hover:text-primary-700" href={`${prefix}/book/`}>The Book</a></li>
          <li><a class="hover:text-primary-700" href={`${prefix}/posts/`}>Blog</a></li>
          <li><a class="hover:text-primary-700" href={`${prefix}/about/`}>About the author</a></li>
          <li><a class="hover:text-primary-700" href="/llms.txt">llms.txt</a></li>
          <li><a class="hover:text-primary-700" href="/sitemap-index.xml">Sitemap</a></li>
        </ul>
      </div>

      <!-- Languages -->
      <div>
        <p class="font-semibold text-stone-800 dark:text-stone-100 mb-3">Languages</p>
        <ul class="space-y-2 text-stone-600 dark:text-stone-400">
          {LANGUAGES.slice(0, 5).map((l) => (
            <li><a class="hover:text-primary-700" href={l.code === "en" ? "/" : `/${l.code}/`}>{l.nativeName}</a></li>
          ))}
          {LANGUAGES.slice(5).map((l) => (
            <li><a class="hover:text-primary-700" href={l.code === "en" ? "/" : `/${l.code}/`}>{l.nativeName}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-stone-200 dark:border-stone-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-stone-500 dark:text-stone-400">
      <p>&copy; {year} What Generative AI &middot; Apache 2.0 Licensed &middot; Built with Astro + Tailwind</p>
      <p>Author <a class="hover:text-primary-700" href="https://www.dipankar.co">Dipankar Sarkar</a> &middot; <a class="hover:text-primary-700" href="https://github.com/dipankar/whatgenerativeai">GitHub</a></p>
    </div>
  </div>
</footer>