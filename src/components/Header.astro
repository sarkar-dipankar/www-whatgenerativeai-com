---
import type { LanguageCode } from "../i18n";
import { LANGUAGES, DEFAULT_LANG, getLang, localizedPath, ui } from "../i18n";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang?: LanguageCode;
  path?: string;
}
const { lang = DEFAULT_LANG, path = "/" } = Astro.props;
const meta = getLang(lang);
const t = (k: keyof typeof ui.en) => (ui as any)[lang]?.[k] ?? ui.en[k];
const navPath = localizedPath(lang, path);
---
<header class="sticky top-0 z-40 border-b border-stone-200/70 bg-stone-50/85 backdrop-blur-md dark:bg-stone-950/85 dark:border-stone-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <a href={localizedPath(lang, "/")} class="flex items-center gap-2.5 font-bold text-stone-900 dark:text-stone-50 hover:text-primary-700 dark:hover:text-primary-300 transition-colors">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary-600 shadow-sm">
        <svg class="h-5 w-5" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <g stroke="#fff" stroke-width="2.6" stroke-linecap="round" transform="translate(16 16)">
            <line x1="0" y1="-9" x2="0" y2="9"/>
            <line x1="-7.8" y1="-4.5" x2="7.8" y2="4.5"/>
            <line x1="-7.8" y1="4.5" x2="7.8" y2="-4.5"/>
          </g>
          <circle cx="16" cy="16" r="2.4" fill="#fbbf24" />
        </svg>
      </span>
      <span class="hidden sm:inline text-base tracking-tight">What <span class="text-primary-700 dark:text-primary-400">Generative AI</span></span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2 text-sm font-medium" aria-label={t("language")}>
      <a href={localizedPath(lang, "/docs/genai-playbook/")} class="px-2.5 py-2 rounded-md hover:bg-stone-100 dark:hover:bg-stone-800 text-stone-700 dark:text-stone-200 transition">{t("navDocs")}</a>
      <a href={localizedPath(lang, "/book/")} class="px-2.5 py-2 rounded-md hover:bg-stone-100 dark:hover:bg-stone-800 text-stone-700 dark:text-stone-200 transition">Book</a>
      <a href={localizedPath(lang, "/posts/")} class="px-2.5 py-2 rounded-md hover:bg-stone-100 dark:hover:bg-stone-800 text-stone-700 dark:text-stone-200 transition">{t("navBlog")}</a>
      <a href={localizedPath(lang, "/about/")} class="px-2.5 py-2 rounded-md hover:bg-stone-100 dark:hover:bg-stone-800 text-stone-700 dark:text-stone-200 transition">{t("navAbout")}</a>
      <ThemeToggle lang={lang} />
    </nav>
  </div>
</header>