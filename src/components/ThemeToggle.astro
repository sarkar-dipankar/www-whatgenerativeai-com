---
import type { LanguageCode } from "../i18n";
import { DEFAULT_LANG } from "../i18n";
interface Props { lang?: LanguageCode }
const { lang = DEFAULT_LANG } = Astro.props;
const labels = {
  en: ["Light", "Dark"],
  it: ["Chiaro", "Scuro"],
  pl: ["Jasny", "Ciemny"],
  ta: ["வெளிச்சம்", "இருள்"],
  ko: ["밝게", "어둡게"],
  he: ["בהיר", "כהה"],
  fi: ["Vaalea", "Tumma"],
  ar: ["فاتح", "داكن"],
  nl: ["Licht", "Donker"],
  de: ["Hell", "Dunkel"],
}[lang] ?? ["Light", "Dark"];
---
<button
  id="theme-toggle"
  type="button"
  class="inline-flex items-center justify-center h-9 w-9 rounded-md hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-600 dark:text-ink-300"
  aria-label="Toggle theme"
  data-light={labels[0]}
  data-dark={labels[1]}
>
  <svg class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.36 6.36l-.71-.71M6.34 6.34l-.7-.7m12.72 0l-.71.71M6.34 17.66l-.7.7M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
  <svg class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20.35 13.35A8 8 0 119.65 2.65a7 7 0 1010.7 10.7z" /></svg>
</button>
<script is:inline>
  (function () {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      root.classList.toggle("dark");
      localStorage.setItem("wgai-theme", root.classList.contains("dark") ? "dark" : "light");
    });
  })();
</script>