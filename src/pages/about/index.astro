---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { DEFAULT_LANG } from "../../i18n";

const siteUrl = "https://www.whatgenerativeai.com";
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Dipankar Sarkar",
  url: "https://www.dipankar.co",
  jobTitle: "Author, GenAI Playbook",
  sameAs: ["https://twitter.com/dipankarsarkar", "https://www.linkedin.com/in/dipankarsarkar", "https://github.com/dipankar", "https://www.amazon.com/Dipankar-Sarkar/e/B0053F136C/"],
  knowsAbout: ["Generative AI", "AI Strategy", "Digital Transformation", "AI Security", "People Analytics"],
  worksFor: { "@type": "Organization", name: "What Generative AI" },
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl + "/" },
    { "@type": "ListItem", position: 2, name: "Author", item: `${siteUrl}/about/` },
  ],
};
---
<BaseLayout
  lang="en"
  title="About the Author — Dipankar Sarkar"
  description="Dipankar Sarkar is the author of the GenAI Playbook at whatgenerativeai.com — an open-source guide helping business leaders implement Generative AI with strategy, security, and measurable ROI."
  jsonLd={[personJsonLd, breadcrumbJsonLd]}
>
  <Header lang="en" path="/about/" />
  <main id="main" class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-ink-500 mb-3" aria-label="Breadcrumb"><a href="/" class="hover:text-brand-700">Home</a> <span aria-hidden="true">/</span> <span class="text-ink-700">Author</span></nav>
    <article class="prose">
      <h1>Dipankar Sarkar</h1>
      <p class="text-lg text-ink-600 dark:text-ink-400 -mt-2">Author, The GenAI Playbook</p>
      <p>Dipankar Sarkar is the author of <strong>The GenAI Playbook</strong> — an open-source, executive-grade guide to implementing Generative AI in organizations. He writes about practical AI adoption: strategy, security, data foundations, people analytics, and measurable ROI.</p>
      <p>The Playbook is published in 10 languages under the Apache 2.0 license and is used by CXOs, IT leaders, and innovation managers worldwide to navigate Generative AI adoption — from core concepts to future-proofing.</p>
      <h2>Expertise</h2>
      <ul>
        <li>Generative AI strategy and enterprise adoption</li>
        <li>AI security, compliance, and governance (GDPR, EU AI Act)</li>
        <li>AI-powered people analytics and HR transformation</li>
        <li>Data engineering for GenAI applications</li>
        <li>Measuring ROI of AI initiatives</li>
      </ul>
      <h2>Connect</h2>
      <ul>
        <li>Email: <a href="mailto:contact@whatgenerativeai.com">contact@whatgenerativeai.com</a></li>
        <li>X/Twitter: <a href="https://twitter.com/dipankarsarkar">@dipankarsarkar</a></li>
        <li>LinkedIn: <a href="https://www.linkedin.com/in/dipankarsarkar">dipankarsarkar</a></li>
        <li>GitHub: <a href="https://github.com/dipankar">dipankar</a></li>
      </ul>
    </article>
  </main>
  <Footer lang="en" />
</BaseLayout>