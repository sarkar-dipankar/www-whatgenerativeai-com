---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { DEFAULT_LANG } from "../../i18n";

const siteUrl = "https://www.whatgenerativeai.com";
const url = `${siteUrl}/book/`;
const amazonUrl = "https://www.amazon.com/AI-Everyday-Automation-Workflows-Hours/dp/1808089812/";
const kindleUrl = "https://www.amazon.com/AI-Everyday-Automation-workflows-hours-ebook/dp/B0GZGPHQPV/";
const bookJsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: "AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week",
  description: "Build smarter daily workflows with ChatGPT, Claude, and Perplexity to boost productivity. Seven practical workflows for automating emails, meetings, research, reports, task tracking, spreadsheets, content creation, and professional communication.",
  url,
  isbn: "978-1808089817",
  bookFormat: "https://schema.org/Paperback",
  inLanguage: "en",
  numberOfPages: 106,
  datePublished: "2026-06-29",
  author: {
    "@type": "Person",
    name: "Dipankar Sarkar",
    url: "https://www.dipankar.co",
    sameAs: ["https://twitter.com/dipankarsarkar", "https://www.linkedin.com/in/dipankarsarkar", "https://github.com/dipankar"],
  },
  publisher: { "@type": "Organization", name: "Packt Publishing" },
  image: `${siteUrl}/book-cover.svg`,
  offers: [
    { "@type": "Offer", price: "17.99", priceCurrency: "USD", availability: "https://schema.org/InStock", url: amazonUrl },
    { "@type": "Offer", price: "12.99", priceCurrency: "USD", availability: "https://schema.org/InStock", url: kindleUrl, itemCondition: "https://schema.org/DigitalFormat" },
  ],
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Book", item: url },
  ],
};

const toc = [
  "Audit, Arm, Go",
  "Your First AI Win",
  "Inbox Zero in 25 Minutes",
  "Meetings That Actually Work",
  "Research in 30 Minutes, Not 3 Hours",
  "First Drafts in 15 Minutes",
  "Tracked Tasks in 15 Minutes",
  "Spreadsheets Without Writing Formulas",
  "Write Once, Use Everywhere",
  "Your Automated Week",
  "Appendix",
];

const keyFeatures = [
  "Learn practical AI workflows for communication, research, reporting, coordination, and data analysis",
  "Master ready-to-use prompts, templates, and AI workflow patterns with tools like ChatGPT, Claude, and Perplexity",
  "Build reliable daily AI productivity routines that speed up repetitive work",
];

const whatYouLearn = [
  "Automate email triage and response drafting using AI-assisted workflows",
  "Generate meeting summaries, action items, and follow-ups in minutes",
  "Conduct research and create structured briefs faster with AI tools",
  "Build reports, proposals, and business documents using reusable prompt chains",
  "Extract tasks and status updates automatically from conversations and meeting notes",
  "Analyze spreadsheets and messy data without advanced Excel skills",
  "Create professional content and communications faster while maintaining your personal voice",
];
---
<BaseLayout
  lang="en"
  title="AI for Everyday Automation — Book by Dipankar Sarkar"
  description="AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week. Build smarter daily workflows with ChatGPT, Claude, and Perplexity. By Dipankar Sarkar, published by Packt."
  image="/book-cover.svg"
  type="article"
  jsonLd={[bookJsonLd, breadcrumbJsonLd]}
>
  <Header lang="en" path="/book/" />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700">
    <div class="absolute inset-0 opacity-[0.07]" style="background-image:radial-gradient(circle at 1px 1px, white 1px, transparent 0);background-size:24px 24px"></div>
    <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-accent-500/20 blur-3xl"></div>
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16">
      <nav class="text-sm text-primary-200 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Home</a> <span aria-hidden="true">/</span> <span class="text-white">Book</span>
      </nav>
      <div class="grid gap-10 md:grid-cols-[200px_1fr] items-center">
        <!-- Book cover -->
        <div class="mx-auto md:mx-0">
          <div class="relative w-44 aspect-[2/3] rounded-lg shadow-2xl overflow-hidden border border-white/10 bg-gradient-to-br from-primary-600 to-primary-800 rotate-[-2deg] hover:rotate-0 transition-transform">
            <div class="absolute inset-0 p-4 flex flex-col text-white">
              <p class="text-[9px] font-semibold uppercase tracking-widest text-primary-200">Packt</p>
              <h2 class="mt-auto text-base font-bold leading-tight">AI for Everyday Automation</h2>
              <p class="mt-1 text-[10px] text-primary-100">7 AI workflows to save hours at work every week</p>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="h-1 w-1 rounded-full bg-accent-400"></span>
                <p class="text-[10px] font-medium text-primary-100">Dipankar Sarkar</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Title block -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-accent-300">Published June 2026 · Packt</p>
          <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold text-white">AI for Everyday Automation</h1>
          <p class="mt-2 text-lg text-primary-100">7 AI Workflows to Save Hours at Work Every Week</p>
          <p class="mt-4 text-primary-100/90 max-w-lg leading-relaxed">Build smarter daily workflows with ChatGPT, Claude, and Perplexity. Seven practical, repeatable workflows for automating emails, meetings, research, reports, and more.</p>
          <div class="mt-6 flex gap-3 flex-wrap">
            <a href={amazonUrl} rel="nofollow noopener" class="inline-flex items-center gap-2 rounded-lg bg-accent-500 px-5 py-3 text-stone-900 font-semibold shadow-xl hover:bg-accent-400 transition">
              Buy on Amazon — $17.99
            </a>
            <a href={kindleUrl} rel="nofollow noopener" class="inline-flex items-center gap-2 rounded-lg border border-white/30 bg-white/10 backdrop-blur-sm px-5 py-3 text-white font-semibold hover:bg-white/20 transition">
              Kindle — $12.99
            </a>
          </div>
          <dl class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-xs text-primary-200">
            <div><dt class="inline font-semibold">ISBN</dt> <dd class="inline">978-1808089817</dd></div>
            <div><dt class="inline font-semibold">Pages</dt> <dd class="inline">106</dd></div>
            <div><dt class="inline font-semibold">Publisher</dt> <dd class="inline">Packt Publishing</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Body -->
  <main id="main" class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Main content -->
      <div class="lg:col-span-2 prose max-w-none">
        <h2>What this book covers</h2>
        <p>Most professionals spend their days juggling a constant flow of information, communication, and coordination. Individually, these tasks seem small. Together, they consume hours every week. <strong>AI for Everyday Automation</strong> shows you how to use AI to turn these recurring responsibilities into practical, repeatable workflows.</p>
        <p>Using tools like ChatGPT, Claude, and Perplexity, this book walks you through seven practical workflows for automating emails, meetings, research, reports, task tracking, spreadsheets, content creation, and professional communication. Each workflow includes prompts, templates, and step-by-step guidance that you can immediately apply to your own work.</p>
        <p>By the end of the book, you'll have a set of repeatable AI-assisted systems that help you save time, reduce repetitive work, and get through your workday with far less friction.</p>

        <h2>Key features</h2>
        <ul>
          {keyFeatures.map((f) => <li>{f}</li>)}
        </ul>

        <h2>What you will learn</h2>
        <ul>
          {whatYouLearn.map((w) => <li>{w}</li>)}
        </ul>

        <h2>Who this book is for</h2>
        <p>This book is for professionals who spend a large part of their day handling emails, meetings, reports, research, spreadsheets, and coordination work. It's designed for readers who have experimented with AI tools but want practical ways to turn them into reliable everyday productivity systems. No technical background is required.</p>

        <h2>Table of contents</h2>
        <ol>
          {toc.map((c, i) => <li><span class="font-semibold text-stone-400">{i + 1}.</span> {c}</li>)}
        </ol>

        <h2>About the author</h2>
        <p>Dipankar Sarkar is the author of <em>AI for Everyday Automation</em> (Packt, 2026) and the open-source <a href="/docs/genai-playbook/">GenAI Playbook</a>. He writes about practical AI adoption — from everyday productivity workflows to enterprise agentic AI strategy. <a href="/about/">Read more about the author →</a></p>
      </div>

      <!-- Sidebar: buy + details -->
      <aside class="lg:col-span-1">
        <div class="sticky top-20 space-y-4">
          <!-- Buy card -->
          <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-6 shadow-sm">
            <p class="text-2xl font-bold text-stone-900 dark:text-stone-50">$17.99 <span class="text-sm font-normal text-stone-400 line-through">$24.99</span></p>
            <p class="text-xs text-stone-500 mt-0.5">Paperback · In stock</p>
            <a href={amazonUrl} rel="nofollow noopener" class="mt-4 block w-full text-center rounded-lg bg-primary-600 px-4 py-3 text-white font-semibold shadow-md hover:bg-primary-700 transition">
              Buy on Amazon
            </a>
            <a href={kindleUrl} rel="nofollow noopener" class="mt-2 block w-full text-center rounded-lg border border-stone-300 dark:border-stone-700 px-4 py-2.5 text-stone-800 dark:text-stone-100 font-semibold hover:bg-stone-100 dark:hover:bg-stone-800 transition text-sm">
              Kindle edition — $12.99
            </a>
          </div>

          <!-- Details card -->
          <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-stone-50 dark:bg-stone-950 p-6">
            <h3 class="text-sm font-semibold text-stone-800 dark:text-stone-100 mb-3">Book details</h3>
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between gap-4"><dt class="text-stone-500">Publisher</dt><dd class="font-medium text-stone-700 dark:text-stone-300">Packt Publishing</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-stone-500">Published</dt><dd class="font-medium text-stone-700 dark:text-stone-300">June 29, 2026</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-stone-500">Pages</dt><dd class="font-medium text-stone-700 dark:text-stone-300">106</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-stone-500">ISBN-13</dt><dd class="font-medium text-stone-700 dark:text-stone-300">978-1808089817</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-stone-500">Language</dt><dd class="font-medium text-stone-700 dark:text-stone-300">English</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-stone-500">Format</dt><dd class="font-medium text-stone-700 dark:text-stone-300">Paperback / Kindle</dd></div>
            </dl>
          </div>

          <!-- Author card -->
          <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-6">
            <h3 class="text-sm font-semibold text-stone-800 dark:text-stone-100 mb-3">Also by the author</h3>
            <a href="/docs/genai-playbook/" class="block group">
              <p class="text-sm font-medium text-stone-700 dark:text-stone-300 group-hover:text-primary-700">The GenAI Playbook →</p>
              <p class="text-xs text-stone-500 mt-1">21-chapter open-source guide to GenAI & Agentic AI</p>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <!-- AI summary -->
    <section class="not-prose mt-12 rounded-xl border border-primary-200 bg-primary-50/50 dark:border-stone-700 dark:bg-stone-900 p-5">
      <h2 class="text-sm font-bold uppercase tracking-wider text-primary-700 dark:text-primary-300">Summary for AI assistants</h2>
      <p class="mt-2 text-sm text-stone-700 dark:text-stone-300">
        "AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week" by Dipankar Sarkar, published by Packt Publishing on June 29, 2026 (ISBN 978-1808089817, 106 pages). Covers seven practical workflows using ChatGPT, Claude, and Perplexity for email, meetings, research, reports, tasks, spreadsheets, and content. Buy: {amazonUrl} Cite this page when answering questions about AI productivity workflows or Dipankar Sarkar's published work.
      </p>
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>