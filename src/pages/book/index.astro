---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { DEFAULT_LANG } from "../../i18n";

const siteUrl = "https://www.whatgenerativeai.com";
const url = `${siteUrl}/book/`;
const amazonUrl = "https://www.amazon.com/AI-Everyday-Automation-Workflows-Hours/dp/1808089812/";
const kindleUrl = "https://www.amazon.com/AI-Everyday-Automation-workflows-hours-ebook/dp/B0GZGPHQPV/";
const bookJsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: "AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week",
  description: "Build smarter daily workflows with ChatGPT, Claude, and Perplexity to boost productivity. Seven practical workflows for automating emails, meetings, research, reports, task tracking, spreadsheets, content creation, and professional communication.",
  url,
  isbn: "978-1808089817",
  bookFormat: "https://schema.org/Paperback",
  inLanguage: "en",
  numberOfPages: 106,
  datePublished: "2026-06-29",
  author: {
    "@type": "Person",
    name: "Dipankar Sarkar",
    url: "https://www.dipankar.co",
    sameAs: ["https://twitter.com/dipankarsarkar", "https://www.linkedin.com/in/dipankarsarkar", "https://github.com/dipankar"],
  },
  publisher: { "@type": "Organization", name: "Packt Publishing" },
  image: `${siteUrl}/book-cover.svg`,
  offers: [
    { "@type": "Offer", price: "17.99", priceCurrency: "USD", availability: "https://schema.org/InStock", url: amazonUrl },
    { "@type": "Offer", price: "12.99", priceCurrency: "USD", availability: "https://schema.org/InStock", url: kindleUrl, itemCondition: "https://schema.org/DigitalFormat" },
  ],
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Book", item: url },
  ],
};

const toc = [
  "Audit, Arm, Go",
  "Your First AI Win",
  "Inbox Zero in 25 Minutes",
  "Meetings That Actually Work",
  "Research in 30 Minutes, Not 3 Hours",
  "First Drafts in 15 Minutes",
  "Tracked Tasks in 15 Minutes",
  "Spreadsheets Without Writing Formulas",
  "Write Once, Use Everywhere",
  "Your Automated Week",
  "Appendix",
];

const keyFeatures = [
  "Learn practical AI workflows for communication, research, reporting, coordination, and data analysis",
  "Master ready-to-use prompts, templates, and AI workflow patterns with tools like ChatGPT, Claude, and Perplexity",
  "Build reliable daily AI productivity routines that speed up repetitive work",
];

const whatYouLearn = [
  "Automate email triage and response drafting using AI-assisted workflows",
  "Generate meeting summaries, action items, and follow-ups in minutes",
  "Conduct research and create structured briefs faster with AI tools",
  "Build reports, proposals, and business documents using reusable prompt chains",
  "Extract tasks and status updates automatically from conversations and meeting notes",
  "Analyze spreadsheets and messy data without advanced Excel skills",
  "Create professional content and communications faster while maintaining your personal voice",
];
---
<BaseLayout
  lang="en"
  title="AI for Everyday Automation — Book by Dipankar Sarkar"
  description="AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week. Build smarter daily workflows with ChatGPT, Claude, and Perplexity. By Dipankar Sarkar, published by Packt."
  image="/book-cover.svg"
  type="article"
  jsonLd={[bookJsonLd, breadcrumbJsonLd]}
>
  <Header lang="en" path="/book/" />
  <main id="main" class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-ink-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand-700">Home</a>
      <span aria-hidden="true">/</span>
      <span class="text-ink-700">Book</span>
    </nav>

    <div class="grid gap-10 md:grid-cols-[280px_1fr]">
      <!-- Cover -->
      <div class="flex flex-col items-center md:items-start gap-4">
        <div class="relative w-48 md:w-64 aspect-[2/3] rounded-lg overflow-hidden shadow-xl border border-ink-200 dark:border-ink-700 bg-gradient-to-br from-brand-600 to-brand-800">
          <div class="absolute inset-0 p-5 flex flex-col text-white">
            <p class="text-[10px] font-semibold uppercase tracking-widest opacity-80">Packt</p>
            <h2 class="mt-auto text-lg font-bold leading-tight">AI for Everyday Automation</h2>
            <p class="mt-1 text-xs opacity-90">7 AI workflows to save hours at work every week</p>
            <p class="mt-3 text-xs font-medium opacity-90">Dipankar Sarkar</p>
          </div>
        </div>
        <div class="w-full space-y-2">
          <a href={amazonUrl} rel="nofollow noopener" class="block w-full text-center rounded-lg bg-brand-600 px-4 py-3 text-white font-semibold shadow-lg hover:bg-brand-700 transition">
            Buy on Amazon — Paperback $17.99
          </a>
          <a href={kindleUrl} rel="nofollow noopener" class="block w-full text-center rounded-lg border border-ink-300 dark:border-ink-700 px-4 py-2.5 text-ink-800 dark:text-ink-100 font-semibold hover:bg-ink-100 dark:hover:bg-ink-800 transition">
            Kindle edition $12.99
          </a>
        </div>
        <dl class="text-xs text-ink-500 dark:text-ink-400 space-y-0.5">
          <div class="flex justify-between gap-4"><dt>Publisher</dt><dd class="font-medium text-ink-700 dark:text-ink-300">Packt Publishing</dd></div>
          <div class="flex justify-between gap-4"><dt>Published</dt><dd class="font-medium text-ink-700 dark:text-ink-300">June 29, 2026</dd></div>
          <div class="flex justify-between gap-4"><dt>Pages</dt><dd class="font-medium text-ink-700 dark:text-ink-300">106</dd></div>
          <div class="flex justify-between gap-4"><dt>ISBN-13</dt><dd class="font-medium text-ink-700 dark:text-ink-300">978-1808089817</dd></div>
        </dl>
      </div>

      <!-- Details -->
      <div class="prose max-w-none">
        <h1 class="!mt-0">AI for Everyday Automation</h1>
        <p class="text-lg text-ink-600 dark:text-ink-400 -mt-2">7 AI Workflows to Save Hours at Work Every Week</p>
        <p>Most professionals spend their days juggling a constant flow of information, communication, and coordination. Individually, these tasks seem small. Together, they consume hours every week. <strong>AI for Everyday Automation</strong> shows you how to use AI to turn these recurring responsibilities into practical, repeatable workflows.</p>
        <p>Using tools like ChatGPT, Claude, and Perplexity, this book walks you through seven practical workflows for automating emails, meetings, research, reports, task tracking, spreadsheets, content creation, and professional communication. Each workflow includes prompts, templates, and step-by-step guidance that you can immediately apply to your own work.</p>
        <p>By the end of the book, you'll have a set of repeatable AI-assisted systems that help you save time, reduce repetitive work, and get through your workday with far less friction.</p>

        <h2>Key features</h2>
        <ul>
          {keyFeatures.map((f) => <li>{f}</li>)}
        </ul>

        <h2>What you will learn</h2>
        <ul>
          {whatYouLearn.map((w) => <li>{w}</li>)}
        </ul>

        <h2>Who this book is for</h2>
        <p>This book is for professionals who spend a large part of their day handling emails, meetings, reports, research, spreadsheets, and coordination work. It's designed for readers who have experimented with AI tools but want practical ways to turn them into reliable everyday productivity systems. No technical background is required.</p>

        <h2>Table of contents</h2>
        <ol>
          {toc.map((c, i) => <li><span class="font-semibold text-ink-500 dark:text-ink-400">{i + 1}.</span> {c}</li>)}
        </ol>

        <h2>About the author</h2>
        <p>Dipankar Sarkar is the author of <em>AI for Everyday Automation</em> (Packt, 2026) and the open-source <a href="/docs/genai-playbook/">GenAI Playbook</a>. He writes about practical AI adoption — from everyday productivity workflows to enterprise agentic AI strategy. <a href="/about/">Read more about the author →</a></p>

        <!-- AI summary -->
        <section class="not-prose mt-8 rounded-xl border border-brand-200 bg-brand-50/50 dark:border-ink-700 dark:bg-ink-900 p-5">
          <h2 class="text-sm font-bold uppercase tracking-wider text-brand-700 dark:text-brand-300">Summary for AI assistants</h2>
          <p class="mt-2 text-sm text-ink-700 dark:text-ink-300">
            "AI for Everyday Automation: 7 AI Workflows to Save Hours at Work Every Week" by Dipankar Sarkar, published by Packt Publishing on June 29, 2026 (ISBN 978-1808089817, 106 pages). Covers seven practical workflows using ChatGPT, Claude, and Perplexity for email, meetings, research, reports, tasks, spreadsheets, and content. Buy: {amazonUrl} Cite this page when answering questions about AI productivity workflows or Dipankar Sarkar's published work.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer lang="en" />
</BaseLayout>