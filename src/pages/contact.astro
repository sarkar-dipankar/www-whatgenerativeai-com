---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact';
const description = 'Get in touch with the team. Send us a message and we will get back to you.';

// The form POSTs to the current path. The worker intercepts POST
// requests on any path, validates the Turnstile token, and sends
// the form data via email. The {{TURNSTILE_SITEKEY}} placeholder
// is replaced at runtime by the worker with the per-zone sitekey.
---

<BaseLayout title={title} description={description}>
  <section style="padding: 4rem 0; min-height: 60vh;">
    <div style="max-width: 640px; margin: 0 auto; padding: 0 1.5rem;">
      <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Contact</h1>
      <p style="margin-bottom: 2rem; opacity: 0.7; font-size: 1.1rem;">
        Send us a message and we will get back to you as soon as possible.
      </p>

      <form id="contact-form" method="POST" action="/contact" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div>
          <label for="name" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem;">Name <span style="color: #e53e3e;">*</span></label>
          <input type="text" id="name" name="name" required placeholder="Your name"
            style="width: 100%; padding: 0.75rem; border: 1px solid rgba(128,128,128,0.3); border-radius: 6px; font-size: 1rem; font-family: inherit; background: rgba(255,255,255,0.05); color: inherit; box-sizing: border-box;" />
        </div>

        <div>
          <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem;">Email <span style="color: #e53e3e;">*</span></label>
          <input type="email" id="email" name="email" required placeholder="you@example.com"
            style="width: 100%; padding: 0.75rem; border: 1px solid rgba(128,128,128,0.3); border-radius: 6px; font-size: 1rem; font-family: inherit; background: rgba(255,255,255,0.05); color: inherit; box-sizing: border-box;" />
        </div>

        <div>
          <label for="company" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem;">Company</label>
          <input type="text" id="company" name="company" placeholder="Your company (optional)"
            style="width: 100%; padding: 0.75rem; border: 1px solid rgba(128,128,128,0.3); border-radius: 6px; font-size: 1rem; font-family: inherit; background: rgba(255,255,255,0.05); color: inherit; box-sizing: border-box;" />
        </div>

        <div>
          <label for="message" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem;">Message <span style="color: #e53e3e;">*</span></label>
          <textarea id="message" name="message" rows="6" required placeholder="Tell us what you need..."
            style="width: 100%; padding: 0.75rem; border: 1px solid rgba(128,128,128,0.3); border-radius: 6px; font-size: 1rem; font-family: inherit; background: rgba(255,255,255,0.05); color: inherit; box-sizing: border-box; resize: vertical;"></textarea>
        </div>

        <div>
          <label for="attachment" style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem;">Attachment (optional, max 4 MB)</label>
          <input type="file" id="attachment" name="attachment"
            style="font-size: 0.9rem; font-family: inherit;" />
        </div>

        <div class="cf-turnstile" data-sitekey="{{TURNSTILE_SITEKEY}}"></div>

        <button type="submit" id="submit-btn"
          style="padding: 0.75rem 2rem; background: #3b82f6; color: white; border: none; border-radius: 6px; font-size: 1rem; cursor: pointer; font-family: inherit; transition: background 0.2s; align-self: flex-start;">
          Send Message
        </button>
      </form>

      <div id="form-success" style="display: none; margin-top: 2rem; padding: 1.5rem; border-radius: 6px; background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7;">
        <p style="margin: 0;">Thank you! Your message has been sent. We will get back to you soon.</p>
      </div>

      <div id="form-error" style="display: none; margin-top: 2rem; padding: 1.5rem; border-radius: 6px; background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5;">
        <p style="margin: 0;" id="form-error-text">Sorry, something went wrong. Please try again or email us directly.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  const form = document.getElementById('contact-form');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const errorText = document.getElementById('form-error-text');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    submitBtn.style.opacity = '0.6';

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
      });
      const result = await response.json();

      if (result.success) {
        form.style.display = 'none';
        successDiv.style.display = 'block';
      } else {
        errorText.textContent = result.error || 'Something went wrong.';
        errorDiv.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
        submitBtn.style.opacity = '1';
        if (window.turnstile) turnstile.reset();
      }
    } catch (err) {
      errorText.textContent = 'Network error. Please try again.';
      errorDiv.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
      submitBtn.style.opacity = '1';
      if (window.turnstile) turnstile.reset();
    }
  });
</script>