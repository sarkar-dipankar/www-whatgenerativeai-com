---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact — What Generative AI';
const description = 'Questions about the GenAI or Agentic AI Playbook? Suggest a chapter, request a translation, report an error, or ask about implementing Generative AI in your organization.';

// The form POSTs to /contact. The per-zone Cloudflare Worker intercepts
// POST /contact, validates the Turnstile token, and emails the submission.
// The {{TURNSTILE_SITEKEY}} placeholder is replaced at runtime by the
// worker with the per-zone sitekey.
---

<BaseLayout title={title} description={description}>
  <Header lang="en" path="/contact" />
  <main id="main" class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-stone-500 mb-3" aria-label="Breadcrumb"><a href="/" class="hover:text-primary-700">Home</a> <span aria-hidden="true">/</span> <span class="text-stone-700 dark:text-stone-300">Contact</span></nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-stone-900 dark:text-stone-50 mb-3">Contact</h1>
    <p class="text-stone-600 dark:text-stone-400 leading-relaxed mb-8">
      Have a question about the <strong>GenAI Playbook</strong> or <strong>Agentic AI Playbook</strong>? Want to suggest a chapter, request a translation, flag an error, or talk through applying Generative AI in your organization? Send a note and the author will get back to you. Prefer email? Reach us at <a href="mailto:contact@whatgenerativeai.com" class="text-primary-700 dark:text-primary-400 hover:underline">contact@whatgenerativeai.com</a>.
    </p>

    <form id="contact-form" method="POST" action="/contact" enctype="multipart/form-data" class="flex flex-col gap-5">
      <input type="hidden" name="form_type" value="whatgenerativeai-contact" />
      <input type="hidden" name="subject" value="GenAI Playbook — new enquiry from whatgenerativeai.com" />

      <div>
        <label for="name" class="block mb-1.5 font-semibold text-sm text-stone-800 dark:text-stone-200">Name <span class="text-red-500">*</span></label>
        <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your name"
          class="w-full rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-stone-900 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>

      <div>
        <label for="email" class="block mb-1.5 font-semibold text-sm text-stone-800 dark:text-stone-200">Email <span class="text-red-500">*</span></label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com"
          class="w-full rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-stone-900 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>

      <div>
        <label for="company" class="block mb-1.5 font-semibold text-sm text-stone-800 dark:text-stone-200">Company or organization <span class="text-stone-400 font-normal">(optional)</span></label>
        <input type="text" id="company" name="company" autocomplete="organization" placeholder="Where you're adopting GenAI"
          class="w-full rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-stone-900 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>

      <div>
        <label for="message" class="block mb-1.5 font-semibold text-sm text-stone-800 dark:text-stone-200">Message <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" rows="6" required placeholder="Chapter suggestion, translation request, errata, or an implementation question…"
          class="w-full rounded-md border border-stone-300 dark:border-stone-700 bg-white dark:bg-stone-900 px-3 py-2.5 text-stone-900 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-primary-500 resize-y"></textarea>
      </div>

      <div>
        <label for="attachment" class="block mb-1.5 font-semibold text-sm text-stone-800 dark:text-stone-200">Attachment <span class="text-stone-400 font-normal">(optional, max 4 MB)</span></label>
        <input type="file" id="attachment" name="attachment" class="text-sm text-stone-600 dark:text-stone-400" />
      </div>

      <div class="cf-turnstile" data-sitekey="{{TURNSTILE_SITEKEY}}"></div>

      <button type="submit" id="submit-btn"
        class="self-start rounded-lg bg-primary-600 px-6 py-2.5 font-semibold text-white hover:bg-primary-700 transition disabled:opacity-60">
        Send message
      </button>
    </form>

    <div id="form-success" role="status" class="hidden mt-6 rounded-md border border-green-300 bg-green-50 text-green-800 px-4 py-4">
      <p class="m-0">Thank you! Your message has been sent — the author will get back to you soon.</p>
    </div>

    <div id="form-error" role="alert" class="hidden mt-6 rounded-md border border-red-300 bg-red-50 text-red-800 px-4 py-4">
      <p class="m-0" id="form-error-text">Sorry, something went wrong. Please try again or email <a href="mailto:contact@whatgenerativeai.com" class="underline">contact@whatgenerativeai.com</a>.</p>
    </div>
  </main>
  <Footer lang="en" />
</BaseLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const errorText = document.getElementById('form-error-text');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  function resetTurnstile() {
    const w = window as unknown as { turnstile?: { reset: () => void } };
    if (w.turnstile) w.turnstile.reset();
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
      }

      const fail = (msg: string) => {
        if (errorText) errorText.textContent = msg;
        if (errorDiv) errorDiv.classList.remove('hidden');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send message';
        }
        resetTurnstile();
      };

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        const result = await response.json();

        if (result.success) {
          form.style.display = 'none';
          if (errorDiv) errorDiv.classList.add('hidden');
          if (successDiv) successDiv.classList.remove('hidden');
        } else {
          fail(result.error || 'Something went wrong. Please try again.');
        }
      } catch (err) {
        fail('Network error. Please try again.');
      }
    });
  }
</script>
