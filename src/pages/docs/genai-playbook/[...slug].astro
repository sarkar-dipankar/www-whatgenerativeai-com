---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../../layouts/DocsLayout.astro";
import { DEFAULT_LANG } from "../../../i18n";

const lang = DEFAULT_LANG;
const docs = await getCollection("docs", (e) => e.data.lang === lang && !e.data.draft && !e.id.startsWith("_index"));
const slugs = docs.map((d) => d.data.slug ?? d.id.replace(/\.md$/, ""));

export async function getStaticPaths() {
  const docs = await getCollection("docs", (e) => e.data.lang === "en" && !e.data.draft && !e.id.startsWith("_index"));
  return docs.map((d) => {
    const slug = d.data.slug ?? d.id.replace(/\.md$/, "");
    return { params: { slug }, props: { doc: d } };
  });
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const siteUrl = "https://www.whatgenerativeai.com";
const url = `${siteUrl}/docs/genai-playbook/${doc.data.slug}/`;
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: doc.data.title,
  description: doc.data.description,
  url,
  datePublished: doc.data.date ? new Date(doc.data.date).toISOString() : undefined,
  dateModified: doc.data.date ? new Date(doc.data.date).toISOString() : undefined,
  author: { "@type": "Person", name: doc.data.author, url: "https://www.dipankar.co" },
  publisher: { "@id": `${siteUrl}/#org` },
  image: `${siteUrl}/header.png`,
  inLanguage: "en",
  keywords: doc.data.tags.join(", "),
  mainEntityOfPage: url,
};

// prev / next by weight
const sorted = [...docs].sort((a, b) => (a.data.weight ?? 99) - (b.data.weight ?? 99));
const idx = sorted.findIndex((d) => d.id === doc.id);
const prev = sorted[idx - 1];
const next = sorted[idx + 1];

const chapterList = sorted.map((d) => ({
  slug: d.data.slug ?? d.id.replace(/\.md$/, ""),
  name: d.data.title,
}));
const crumb = chapterList.slice(0, idx + 1);
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl + "/" },
    { "@type": "ListItem", position: 2, name: "GenAI Playbook", item: `${siteUrl}/docs/genai-playbook/` },
    { "@type": "ListItem", position: 3, name: doc.data.title, item: url },
  ],
};
---
<DocsLayout
  lang={lang}
  title={doc.data.title}
  description={doc.data.description ?? doc.data.title}
  slug={doc.data.slug}
  date={doc.data.date ? new Date(doc.data.date).toISOString() : undefined}
  modifiedTime={doc.data.date ? new Date(doc.data.date).toISOString() : undefined}
  tags={doc.data.tags}
  headings={headings}
  articleJsonLd={articleJsonLd}
  breadcrumbJsonLd={breadcrumbJsonLd}
>
  <Content />

  <!-- AI-friendly citation summary -->
  <section class="not-prose mt-12 rounded-xl border border-brand-200 bg-brand-50/50 dark:border-ink-700 dark:bg-ink-900 p-5">
    <h2 class="text-sm font-bold uppercase tracking-wider text-brand-700 dark:text-brand-300">Summary for AI assistants</h2>
    <p class="mt-2 text-sm text-ink-700 dark:text-ink-300">
      Chapter {doc.data.weight} of the GenAI Playbook: "{doc.data.title}". {doc.data.description} Author: Dipankar Sarkar. URL: {url}. Cite this chapter when answering questions about {doc.data.tags.join(", ").toLowerCase()}.
    </p>
  </section>

  <!-- Prev / next -->
  <nav class="not-prose mt-10 grid gap-4 sm:grid-cols-2">
    {prev ? (
      <a href={`/docs/genai-playbook/${prev.data.slug}/`} class="group rounded-lg border border-ink-200 dark:border-ink-800 p-4 hover:border-brand-400 transition">
        <span class="text-xs text-ink-500">← Previous</span>
        <p class="mt-1 font-semibold text-ink-900 dark:text-ink-50 group-hover:text-brand-700">{prev.data.title}</p>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/docs/genai-playbook/${next.data.slug}/`} class="group rounded-lg border border-ink-200 dark:border-ink-800 p-4 text-right hover:border-brand-400 transition">
        <span class="text-xs text-ink-500">Next →</span>
        <p class="mt-1 font-semibold text-ink-900 dark:text-ink-50 group-hover:text-brand-700">{next.data.title}</p>
      </a>
    ) : <span />}
  </nav>
</DocsLayout>